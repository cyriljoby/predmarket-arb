# Copy this file to `.env` (gitignored) and fill in your credentials.
# Needed ONLY for the live WebSocket feeds — public REST endpoints need none.

# --- Kalshi --------------------------------------------------------------- #
# Create at: https://kalshi.com/account/profile  ->  API Keys  ->  Create New
# You get a Key ID and a downloaded RSA private key (.txt) shown ONCE.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=~/.secrets/kalshi_private_key.txt

# --- Polymarket US -------------------------------------------------------- #
# Requires the Polymarket US app + identity verification (KYC) FIRST, then:
# https://polymarket.us/developer  ->  create key  ->  Key ID + Secret Key (shown ONCE)
POLYMARKET_US_KEY_ID=
POLYMARKET_US_SECRET_KEY=
